# BuildKit 内置前端，支持 RUN --mount
# 使用PyTorch ARM架构构建器镜像作为基础镜像
# 注意：manylinuxaarch64-builder 是基于 CentOS 的构建器镜像
# 如果 cuda12.9 版本不存在，可以尝试 cuda12.8 或其他可用版本
FROM pytorch/manylinuxaarch64-builder:cuda12.9 AS base

# 设置环境变量
ENV PYTHONUNBUFFERED=1 \
    TZ=Asia/Shanghai \
    CUDA_VISIBLE_DEVICES=0 \
    QT_QPA_PLATFORM=xcb \
    QT_X11_NO_MITSHM=1 \
    PATH=/opt/python/cp311-cp311/bin:/opt/python/cp310-cp310/bin:$PATH

# 设置工作目录
WORKDIR /app

# ======================= 第一阶段：系统依赖安装 =======================
FROM base AS dependencies

# 复制本地 ffmpeg 文件（如果存在，优先使用本地文件）
# 注意：如果文件不存在，构建脚本会创建一个空占位符文件以避免构建失败
# Dockerfile 会在 RUN 命令中检查文件大小，如果文件为空或很小则跳过使用
COPY ffmpeg-master-latest-linuxarm64-gpl.tar.xz* /tmp/

# manylinuxaarch64-builder 基于 CentOS，使用 yum 包管理器
# 安装系统依赖包（包含视频处理所需的ffmpeg和相关库）
RUN set -ex && \
    # 安装基础工具和开发工具
    yum install -y \
        ca-certificates \
        curl \
        wget \
        git \
        vim \
        htop \
        gnupg2 \
        gcc \
        gcc-c++ \
        make \
        cmake \
        which \
        file \
        && \
    # 安装图形库和视频处理库
    yum install -y \
        mesa-libGL \
        mesa-libGL-devel \
        glib2 \
        glib2-devel \
        python3-devel \
        libusb \
        libSM \
        libgomp \
        gtk3 \
        mesa-dri-drivers \
        libX11 \
        libXext \
        libXrender \
        libxcb \
        libxcb-devel \
        libXinerama \
        && \
    # 安装 ffmpeg 和相关库
    # 注意：CentOS/RHEL 8+ 中 ffmpeg 不在 EPEL，需要从其他源安装
    yum install -y \
        epel-release \
        && \
    # 尝试从 EPEL 安装 ffmpeg（CentOS 7 可能可以，CentOS 8+ 会失败）
    if yum install -y ffmpeg ffmpeg-devel 2>/dev/null; then \
        echo "ffmpeg 已从 EPEL 仓库安装"; \
    else \
        echo "ffmpeg 不在 EPEL 仓库中，使用预编译静态二进制文件安装（官方推荐方法）..." && \
        cd /tmp && \
        INSTALLED=0; \
        if [ -f ffmpeg-master-latest-linuxarm64-gpl.tar.xz ] && [ $(stat -c%s ffmpeg-master-latest-linuxarm64-gpl.tar.xz 2>/dev/null || echo 0) -gt 1048576 ]; then \
            echo "使用 COPY 传入的离线 ffmpeg 包..." && \
            tar -xf ffmpeg-master-latest-linuxarm64-gpl.tar.xz && \
            cp ffmpeg-master-latest-linuxarm64-gpl/bin/ffmpeg /usr/local/bin/ && \
            cp ffmpeg-master-latest-linuxarm64-gpl/bin/ffprobe /usr/local/bin/ && \
            chmod +x /usr/local/bin/ffmpeg /usr/local/bin/ffprobe && \
            echo "ffmpeg 已从离线包安装" && \
            INSTALLED=1; \
        else \
            rm -f ffmpeg-master-latest-linuxarm64-gpl.tar.xz; \
        fi; \
        if [ "$INSTALLED" = "0" ]; then \
        echo "尝试从 GitHub BtbN/FFmpeg-Builds 下载 ARM64 版本..." && \
        { if wget -q -L --timeout=120 \
            "https://github.com/BtbN/FFmpeg-Builds/releases/download/latest/ffmpeg-master-latest-linuxarm64-gpl.tar.xz" 2>/dev/null; then \
            if [ -f ffmpeg-master-latest-linuxarm64-gpl.tar.xz ] && [ $(stat -c%s ffmpeg-master-latest-linuxarm64-gpl.tar.xz 2>/dev/null || echo 0) -gt 1048576 ]; then \
                tar -xf ffmpeg-master-latest-linuxarm64-gpl.tar.xz && \
                cp ffmpeg-master-latest-linuxarm64-gpl/bin/ffmpeg /usr/local/bin/ && \
                cp ffmpeg-master-latest-linuxarm64-gpl/bin/ffprobe /usr/local/bin/ && \
                chmod +x /usr/local/bin/ffmpeg /usr/local/bin/ffprobe && \
                echo "ffmpeg 已从 GitHub BtbN/FFmpeg-Builds 安装" && \
                INSTALLED=1; \
            else \
                echo "GitHub 下载文件无效，尝试下一方案..."; \
            fi; \
        else \
            echo "GitHub 下载失败，尝试下一方案..."; \
        fi; } || true; \
        fi; \
        # 方案2：从 johnvansickle.com 下载 ARM64 静态二进制文件
        if [ "$INSTALLED" = "0" ]; then \
            echo "尝试从 johnvansickle.com 下载 ARM64 静态二进制文件..." && \
            { if wget -q -L --timeout=120 \
                "https://johnvansickle.com/ffmpeg/releases/ffmpeg-release-arm64-static.tar.xz" 2>/dev/null; then \
                if [ -f ffmpeg-release-arm64-static.tar.xz ] && [ $(stat -c%s ffmpeg-release-arm64-static.tar.xz 2>/dev/null || echo 0) -gt 1048576 ]; then \
                    tar -xf ffmpeg-release-arm64-static.tar.xz && \
                    cp ffmpeg-*-static/ffmpeg /usr/local/bin/ && \
                    cp ffmpeg-*-static/ffprobe /usr/local/bin/ && \
                    chmod +x /usr/local/bin/ffmpeg /usr/local/bin/ffprobe && \
                    echo "ffmpeg 已从 johnvansickle.com 安装" && \
                    INSTALLED=1; \
                else \
                    echo "johnvansickle 下载文件无效，尝试下一方案..."; \
                fi; \
            else \
                echo "johnvansickle 下载失败，尝试下一方案..."; \
            fi; } || true; \
        fi; \
        # 方案3：从源码编译（最后手段）
        if [ "$INSTALLED" = "0" ]; then \
            echo "预编译版本不可用，使用简化配置从源码编译（不启用所有编解码器）..." && \
            yum install -y nasm yasm && \
            wget -q https://ffmpeg.org/releases/ffmpeg-6.1.1.tar.bz2 && \
            tar -xjf ffmpeg-6.1.1.tar.bz2 && \
            cd ffmpeg-6.1.1 && \
            ./configure \
                --prefix=/usr/local \
                --enable-gpl \
                --enable-version3 \
                --enable-shared \
                --disable-static \
                --enable-pic \
                && \
            make -j$(nproc) && \
            make install && \
            ldconfig && \
            cd / && \
            rm -rf /tmp/ffmpeg-6.1.1* && \
            echo "ffmpeg 已从源码编译安装（简化配置）" && \
            INSTALLED=1; \
        fi; \
        if [ "$INSTALLED" = "0" ]; then \
            echo "ERROR: 所有 ffmpeg 安装方案均失败" && exit 1; \
        fi; \
        rm -rf /tmp/ffmpeg-*; \
    fi \
        && \
    # 清理缓存
    yum clean all && \
    rm -rf /var/cache/yum

# 配置时区
RUN set -ex && \
    ln -sf /usr/share/zoneinfo/$TZ /etc/localtime && \
    echo $TZ > /etc/timezone

# ======================= 第二阶段：Python环境配置 =======================
FROM dependencies AS python-env

# 确保使用正确的 Python 版本（manylinuxaarch64-builder 通常包含多个 Python 版本）
# 优先使用 Python 3.11，如果没有则使用 Python 3.10，最后使用系统 Python
RUN set -ex && \
    if [ -d /opt/python/cp311-cp311 ]; then \
        echo "使用 Python 3.11" && \
        ln -sf /opt/python/cp311-cp311/bin/python3.11 /usr/local/bin/python3 && \
        ln -sf /opt/python/cp311-cp311/bin/pip3.11 /usr/local/bin/pip3 && \
        ln -sf /opt/python/cp311-cp311/bin/python3.11 /usr/local/bin/python; \
    elif [ -d /opt/python/cp310-cp310 ]; then \
        echo "使用 Python 3.10" && \
        ln -sf /opt/python/cp310-cp310/bin/python3.10 /usr/local/bin/python3 && \
        ln -sf /opt/python/cp310-cp310/bin/pip3.10 /usr/local/bin/pip3 && \
        ln -sf /opt/python/cp310-cp310/bin/python3.10 /usr/local/bin/python; \
    else \
        echo "使用系统 Python" && \
        yum install -y python3 python3-pip && \
        yum clean all && \
        ln -sf /usr/bin/python3 /usr/local/bin/python3 && \
        ln -sf /usr/bin/pip3 /usr/local/bin/pip3 && \
        ln -sf /usr/bin/python3 /usr/local/bin/python; \
    fi && \
    python3 --version && \
    pip3 --version && \
    python --version

# ======================= 第三阶段：Python依赖安装 =======================
FROM python-env AS python-deps

# ARM 构建镜像无预装 PyTorch，使用本地全量 requirements.txt
COPY requirements.txt requirements-base.txt ./
COPY --from=pip-wheels . /opt/offline-pip
ARG OFFLINE_MODE=0
ARG PIP_INDEX_URL=https://mirrors.cloud.tencent.com/pypi/simple
ENV PIP_INDEX_URL=${PIP_INDEX_URL}

RUN --mount=type=bind,from=pip-cache,source=.,target=/mnt/pip-cache,rw \
    --mount=type=cache,target=/tmp/pip-wheels-build,id=pip-wheels-build-video-arm \
    set -ex && \
    mkdir -p /mnt/pip-cache/http /tmp/pip-wheels-build && \
    rm -rf /mnt/pip-cache/wheels && \
    ln -sfn /tmp/pip-wheels-build /mnt/pip-cache/wheels && \
    sed -i 's/onnxruntime-gpu/onnxruntime/g' requirements.txt requirements-base.txt && \
    export PIP_CACHE_DIR=/mnt/pip-cache && \
    pip3 install --upgrade pip -i "${PIP_INDEX_URL}" && \
    if [ -n "$(find /opt/offline-pip -maxdepth 1 -type f 2>/dev/null)" ]; then \
        py_tag="$(python3 -c 'import sys; print("cp{}{}".format(sys.version_info.major, sys.version_info.minor))')" && \
        if grep -Eq '^torch([<>= ].*)?$' requirements.txt && ls /opt/offline-pip/torch-*.whl >/dev/null 2>&1; then \
            if ! ls /opt/offline-pip/torch-*-"${py_tag}"-*.whl >/dev/null 2>&1; then \
                echo "离线 wheel ABI 不匹配: ${py_tag}" && exit 1; \
            fi; \
        fi && \
        if [ "$OFFLINE_MODE" = "1" ]; then \
            echo "OFFLINE_MODE=1：仅使用 pip-wheels 离线安装..." && \
            pip3 install -r requirements.txt --no-index --find-links /opt/offline-pip --prefer-binary; \
        elif pip3 install -r requirements.txt --dry-run --no-index --find-links /opt/offline-pip --prefer-binary >/dev/null 2>&1; then \
            echo "pip-wheels 可覆盖全部依赖，离线安装..." && \
            pip3 install -r requirements.txt --no-index --find-links /opt/offline-pip --prefer-binary; \
        else \
            echo "pip-wheels 与 requirements 未完全匹配，使用清华源 + find-links 混合安装..." && \
            pip3 install -r requirements.txt --find-links /opt/offline-pip --prefer-binary -i "${PIP_INDEX_URL}"; \
        fi; \
    elif [ "$OFFLINE_MODE" = "1" ]; then \
        echo "OFFLINE_MODE=1 且无 pip-wheels" && exit 1; \
    else \
        echo "使用清华源 + 宿主机 pip-cache 在线安装..." && \
        pip3 install -r requirements.txt -i "${PIP_INDEX_URL}"; \
    fi

# ======================= 第四阶段：应用部署 =======================
FROM python-deps AS runtime

# 复制项目源码
COPY . .

# 创建必要的目录结构
RUN set -ex && \
    mkdir -p \
        data/uploads \
        data/datasets \
        data/models \
        data/inference_results \
        temp_uploads \
        static/models && \
    # 设置执行权限
    chmod +x run.py

# 创建非root用户和权限设置
RUN set -ex && \
    groupadd -r appuser && \
    useradd -r -m -g appuser appuser && \
    mkdir -p /home/appuser/.paddlex/temp /home/appuser/.config/Ultralytics && \
    chown -R appuser:appuser /app /home/appuser

# 切换到非root用户
USER appuser

# 暴露端口
EXPOSE 6000

# 健康检查
HEALTHCHECK --interval=30s --timeout=10s --start-period=90s --retries=3 \
    CMD curl -fs http://localhost:6000/actuator/health > /dev/null || exit 1

# 启动命令
CMD ["python3", "run.py"]

