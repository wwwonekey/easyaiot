# ============================================
# 抓拍算法服务环境变量配置模板
# ============================================
# 使用方法：
# 1. 复制此文件为 .env: cp env.example .env
# 2. 根据实际情况修改各个配置项
# 3. 注意：.env 文件包含敏感信息，不要提交到版本控制系统
# ============================================
#
# 与 stream_forward / realtime_algorithm 一致的读取优先级（抓拍不推流，无 FFmpeg 编码）：
# - 帧率/分辨率：AI_SOURCE_FPS、AI_TARGET_* → VIEW_SOURCE_FPS、VIEW_TARGET_* → SOURCE_FPS、TARGET_*
# - 画质档位：AI_VIDEO_QUALITY_PROFILE → VIEW_VIDEO_QUALITY_PROFILE → VIDEO_QUALITY_PROFILE
# - RTSP 拉流传输：AI_RTSP_TRANSPORT → OPENCV_FFMPEG_RTSP_TRANSPORT / FFMPEG_RTSP_TRANSPORT → 建议 tcp
# 代码未使用 FFMPEG_PRESET / FFMPEG_VIDEO_BITRATE 等推流相关变量，无需配置。

# ============================================
# 基本配置（必需）
# ============================================
# 算法任务ID（必需）
TASK_ID=

# 数据库配置
DATABASE_URL=postgresql://postgres:iot45722414822@localhost:5432/iot-video

# 视频服务端口（默认6000）
VIDEO_SERVICE_PORT=6000

# 网关地址
GATEWAY_URL=http://localhost:48080

# RTSP 传输（OpenCV/FFmpeg 拉流）：未单独配置 OPENCV_FFMPEG_CAPTURE_OPTIONS 时生效。
# 建议显式 tcp（与 realtime_algorithm_service 一致）；局域网极低延迟可改为 udp
# AI_RTSP_TRANSPORT=tcp

# GB28181 虚拟源 gb28181://（解析详情见日志「GB28181源解析成功」，与 realtime 共用 VIDEO/app/utils/gb28181_source.py）
# GB28181_PLAY_PROTOCOL=rtmp_first
# GB28181_HEVC_RTSP_FIRST=1
# GB28181_SERVICE_URL=http://127.0.0.1:48088/api
#
# OpenCV 拉流（抓拍缓流）：与 realtime 共用 VIDEO/app/utils/async_video_stream.py；默认 RTSP/RTMP 异步解码。
# AI_RTSP_ASYNC_READ=1
# 异步缓冲深度（默认 1=只保留最新帧、追实时；不写环境变量时代码亦为 1）。需 FIFO 顺播时再显式设置，例如弱网/国标：15～60。
# AI_RTSP_ASYNC_QUEUE_MAX=30

# 告警图片根目录（可选）。不设则落盘到仓库内 VIDEO/alert_images。
# Docker 与 iot-sink 对齐见 realtime_algorithm_service/env.example（ALERT_IMAGES_DIR=/app/alert_images）。
#ALERT_IMAGES_DIR=/app/alert_images

# ============================================
# 视频处理（可选；不配则与代码默认一致：25fps、1280x720）
# ============================================
# 以下为低配示例，若要与推流转发同款清晰度可改为 25、1280、720 或删除以使用默认
# AI_SOURCE_FPS=25
# AI_TARGET_WIDTH=1280
# AI_TARGET_HEIGHT=720
# VIEW_SOURCE_FPS=25
# VIEW_TARGET_WIDTH=1280
# VIEW_TARGET_HEIGHT=720
SOURCE_FPS=15
TARGET_WIDTH=640
TARGET_HEIGHT=360

# 抽帧间隔（默认2；抓拍任务还受 cron 控制）
EXTRACT_INTERVAL=2

BUFFER_SIZE=70
MIN_BUFFER_FRAMES=15
MAX_WAIT_TIME=0.08

# YOLO 输入边长（letterbox；画质分档会覆盖部分预设）
YOLO_IMG_SIZE=416

# 抓拍：单设备抽帧队列深度（代码默认1，新顶旧）
EXTRACT_QUEUE_SIZE=1

# 检测结果最大等待（秒），超时未出结果则丢弃该帧上下文
SNAPSHOT_RESULT_MAX_WAIT_SEC=5.0

# ============================================
# 队列与检测线程
# ============================================
DETECTION_QUEUE_SIZE=100
PUSH_QUEUE_SIZE=100
YOLO_WORKER_THREADS=2

# ============================================
# 其他
# ============================================
PYTHONUNBUFFERED=1
TZ=Asia/Shanghai
