# Git / IDE
.git
.gitignore
.idea
.vscode
*.iml

# Python 缓存
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/

# 日志与临时文件
*.log
*.tmp
*.temp
*~

# 运行时数据（compose 卷挂载）
uploads/
static/annotations/

# 环境变量（运行时卷挂载）
.env
.env.*
!.env.example
!.env.docker

# 安装 / 缓存脚本
*.sh
cache_resources*.sh

# Docker 构建元数据（勿打入 runtime 层；requirements-* 须在上下文中供 python-deps COPY）
Dockerfile*
.dockerignore

# 文档
*.md
README*

# 系统文件
.DS_Store
Thumbs.db
