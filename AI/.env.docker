# ============================================
# AI服务环境变量配置
# ============================================
# 注意：此文件包含敏感信息，不要提交到版本控制系统
# ============================================

# ============================================
# Flask应用配置
# ============================================
# Flask密钥（用于会话加密）
SECRET_KEY=8595796f2b6c5aefbc2f0d0442d9fcf7c4142ae27fa2bf14acc2f2b88352a2e35b0c35d17006709a

# Flask运行端口（默认5000）
FLASK_RUN_PORT=5000

# Flask运行主机（默认0.0.0.0）
FLASK_RUN_HOST=0.0.0.0

# Flask调试模式（生产环境建议设置为False）
DEBUG=True

# 允许的主机列表（生产环境建议设置具体域名）
ALLOWED_HOSTS=[*]

# ============================================
# 数据库配置
# ============================================
# PostgreSQL数据库连接URL
# 格式: postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql://postgres:iot45722414822@localhost:5432/iot-ai20

# ============================================
# Nacos服务注册与发现配置
# ============================================
# Nacos服务器地址（格式：IP:端口）
NACOS_SERVER=localhost:8848

# Nacos命名空间（默认：local）
NACOS_NAMESPACE=

# Nacos用户名（默认：nacos）
NACOS_USERNAME=nacos

# Nacos密码
NACOS_PASSWORD=basiclab@iot78475418754

# 服务名称（用于Nacos注册）
SERVICE_NAME=model-server

# Pod IP地址（可选，如果不设置会自动获取）
# 在Docker容器中运行时，建议设置为容器的IP地址
POD_IP=

# Java 网关地址（数据集图片列表、上传等内部 API，默认与 iot-gateway 一致）
JAVA_BACKEND_URL=http://localhost:48080

# ============================================
# MinIO对象存储配置
# ============================================
# MinIO服务器地址（格式：IP:端口）
MINIO_ENDPOINT=localhost:9000

# MinIO访问密钥
MINIO_ACCESS_KEY=minioadmin

# MinIO密钥
MINIO_SECRET_KEY=basiclab@iot975248395

# MinIO是否使用HTTPS（true/false）
MINIO_SECURE=false

# ============================================
# GPU配置
# ============================================
# CUDA可见设备（0表示使用第一个GPU，all表示使用所有GPU）
# 在docker-compose.yaml中已配置，这里可以覆盖
CUDA_VISIBLE_DEVICES=0

# ============================================
# 讯飞语音识别配置（可选）
# ============================================
# 讯飞APP ID（如果不需要语音识别功能，可以留空）
XUNFEI_APP_ID=

# 讯飞密钥（如果不需要语音识别功能，可以留空）
XUNFEI_SECRET_KEY=

# ============================================
# 模型推流配置（可选）
# ============================================
# 模型推流地址
MODEL_AI_PUSH_URL=pro.basiclab.top:1935

# ============================================
# 其他配置
# ============================================
# Python输出不缓冲（建议设置为1）
PYTHONUNBUFFERED=1

# 时区设置
TZ=Asia/Shanghai

# ============================================
# 代理配置（可选，如果需要）
# ============================================
# HTTP_PROXY=
# HTTPS_PROXY=
# NO_PROXY=localhost,127.0.0.1

# ============================================
# GPU推理配置
# ============================================
# 是否启用GPU（训练与推理）
USE_GPU=False
# 指定GPU索引，逗号分隔；留空则自动探测全部可见GPU
# GPU_IDS=0,1
# Docker NVIDIA设备可见性
NVIDIA_VISIBLE_DEVICES=all

# ============================================
# SAM 3.1 万物分割 / 冷启动自动标注（可选）
# ============================================
# 是否启用 SAM 推理与自动标注（true/false）
SAM_ENABLED=true

# 推理引擎：sam3（Ultralytics SAM3SemanticPredictor，支持 sam3*.pt 权重）
SAM_ENGINE=sam3

# 模型权重本地路径（默认 AI/models/sam3/sam3.1_multiplex.pt）
# SAM_MODEL_PATH=/projects/easyaiot/AI/models/sam3/sam3.1_multiplex.pt

# 魔塔 ModelScope 下载源（默认，无需额外配置直链）
SAM_MODELSCOPE_ID=facebook/sam3.1
SAM_MODELSCOPE_FILE=sam3.1_multiplex.pt

# 置信度、输入尺寸
SAM_CONF=0.45
SAM_IMGSZ=1078

# MinIO 桶名（SAM 图片/权重备份）
SAM_MINIO_BUCKET=sam-models

# ============================================
# 自动标注模型
# ============================================
# 每个数据集保留的模型更新历史条数（1–100，默认 15）
# AUTO_LABEL_MODEL_HISTORY_MAX=15
# 触发模型更新所需最少已标注张数
# AUTO_LABEL_MODEL_MIN_ANNOTATED=10
EASYAIOT_DEPLOY_PROFILE=full
GATEWAY_URL=http://localhost:48080
NODE_REMOTE_DEPLOY=true
AUTH_CHECK_URL=http://localhost:48080/admin-api/system/auth/get-permission-info
MINIO_SEED_DATA_ROOT=/minio-seed-data
