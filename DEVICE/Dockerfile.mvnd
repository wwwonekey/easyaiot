# C2 常驻 builder 镜像：glibc 基础 + Apache mvnd（Maven Daemon）
# 由 install_linux.sh 在 USE_MVND=1 时自建：docker build -f Dockerfile.mvnd -t device-mvnd:latest .
#
# 基础镜像须 glibc（mvnd 原生客户端 glibc 链接，不支持 Alpine/musl）。
# 默认 bellsoft/liberica-openjdk-debian:21.0.8——运行时阶段已在用、服务器必定可拉取，
# 避免 eclipse-temurin 从 docker.io 拉取失败（liberica-openjdk 为完整 JDK，含 javac）。
ARG MVND_BASE_IMAGE=bellsoft/liberica-openjdk-debian:21.0.8
FROM ${MVND_BASE_IMAGE}

# 可经 --build-arg 覆盖：mvnd 版本与下载源（默认清华源）
ARG MVND_VERSION=1.0.6
ARG MVND_BASE_URL=https://mirrors.tuna.tsinghua.edu.cn/apache/maven/mvnd

# 下载并安装 mvnd 到 /opt/mvnd（ADD 远程 tar 不自动解压，需手动 tar）
ADD ${MVND_BASE_URL}/${MVND_VERSION}/maven-mvnd-${MVND_VERSION}-linux-amd64.tar.gz /tmp/mvnd.tgz
RUN mkdir -p /opt/mvnd \
 && tar -xzf /tmp/mvnd.tgz -C /opt/mvnd --strip-components=1 \
 && rm /tmp/mvnd.tgz \
 && ln -s /opt/mvnd/bin/mvnd /usr/local/bin/mvnd \
 && mvnd --version

ENV MVND_HOME=/opt/mvnd

# 容器长存：mvnd daemon 由首个 `docker exec mvnd ...` 拉起并常驻，跨次 update 复用
CMD ["sleep", "infinity"]
